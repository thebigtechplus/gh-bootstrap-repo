#!/usr/bin/env bash
# gh extension: gh bootstrap-repo
# Downloads the canonical script from thebigtechplus/.github via the GitHub API (requires gh).
set -euo pipefail

ORG_REPO="${BTP_BOOTSTRAP_SOURCE_REPO:-thebigtechplus/.github}"
SCRIPT_PATH="${BTP_BOOTSTRAP_SCRIPT_PATH:-scripts/bootstrap-repo.sh}"

if ! command -v gh >/dev/null 2>&1; then
  echo "error: GitHub CLI (gh) is required. Install: https://cli.github.com/" >&2
  exit 1
fi

if ! gh auth status >/dev/null 2>&1; then
  echo "error: gh is not authenticated. Run: gh auth login" >&2
  exit 1
fi

b64_decode() {
  if command -v openssl >/dev/null 2>&1; then
    openssl base64 -d -A 2>/dev/null || openssl base64 -d
  else
    base64 --decode 2>/dev/null || base64 -d
  fi
}

TMP="$(mktemp "${TMPDIR:-/tmp}/btp-bootstrap.XXXXXX")"
cleanup() { rm -f "$TMP"; }
trap cleanup EXIT

# Prefer GitHub API over raw.githubusercontent.com to avoid CDN staleness
if ! gh api "repos/${ORG_REPO}/contents/${SCRIPT_PATH}" --jq .content | tr -d '\n' | b64_decode >"$TMP"; then
  echo "error: failed to download ${SCRIPT_PATH} from ${ORG_REPO}" >&2
  exit 1
fi

chmod +x "$TMP"
bash "$TMP" "$@"
